# =============================================================================
# CONNEXTED LABS — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values.
# Never commit .env to source control.
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE — Required for all operations
# Create a project at https://supabase.com, then find these in:
# Project Settings > API
# -----------------------------------------------------------------------------

# Your Supabase project URL (e.g. https://abcdefghijkl.supabase.co)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase project ID (the subdomain part of the URL above)
VITE_SUPABASE_PROJECT_ID=your-project-id

# Supabase anonymous/public key — safe to expose in the browser
# Project Settings > API > Project API keys > anon public
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase service role key — NEVER expose this in the browser
# Backend API only. Project Settings > API > Project API keys > service_role
# This key bypasses Row Level Security — keep it secret.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Full PostgreSQL connection string for Drizzle ORM migrations
# Project Settings > Database > Connection string > URI
DATABASE_URL=postgresql://postgres:your-password@db.your-project-id.supabase.co:5432/postgres

# -----------------------------------------------------------------------------
# SERVER — Required for both frontend (dev) and API server
# -----------------------------------------------------------------------------

# Port number for the server process
# Vercel/Railway will inject this automatically in production
PORT=3000

# Base path for the frontend application
# Use "/" for a standard deployment at the root domain
# Use "/community-name" if hosting multiple apps on one domain
BASE_PATH=/

# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------

# Set to "production" for deployed environments, "development" for local
NODE_ENV=development

# Logging level: trace | debug | info | warn | error | fatal
# Use "info" for production, "debug" for local development
LOG_LEVEL=info
